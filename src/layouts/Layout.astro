---
import "../styles/global.css";
import { pwaInfo } from "virtual:pwa-info";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Baby Sleep Tracker — Track baby sleeps, offline",
  description = "A tiny offline-first PWA to track your baby's sleep. One tap to start a nap, swipe to browse the last 14 days, with daily totals and per-session charts. No account, no servers — everything stays on your phone.",
} = Astro.props;

// Normalize base so it always ends in a slash — Astro's BASE_URL may or
// may not, depending on the configured `base`.
const rawBase = import.meta.env.BASE_URL;
const baseUrl = rawBase.endsWith("/") ? rawBase : `${rawBase}/`;
const asset = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
const ogImage = asset("favicon.svg");
const canonical = Astro.url
  ? new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString()
  : (Astro.site ? new URL(baseUrl, Astro.site).toString() : baseUrl);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Lukas Chylik" />
    <meta name="keywords" content="baby sleep tracker, baby nap tracker, infant sleep log, offline PWA, sleep history, baby sleep chart" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Baby Sleep Tracker" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- App / mobile -->
    <meta name="theme-color" content="#07061a" />
    <meta name="color-scheme" content="dark" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Baby Sleep" />
    <meta name="application-name" content="Baby Sleep" />
    <meta name="format-detection" content="telephone=no" />

    <link rel="icon" type="image/svg+xml" href={asset("favicon.svg")} />
    <link rel="apple-touch-icon" href={asset("favicon.svg")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet" />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
  </head>
  <body class="overflow-hidden">
    <!-- Status-bar backdrop: paints over the iOS notch / Dynamic Island area -->
    <div class="safe-area-top" aria-hidden="true"></div>
    <slot />
    <script>
      import { registerSW } from "virtual:pwa-register";
      // Auto-update on new deployment; handle silently — no nag prompts.
      const updateSW = registerSW({
        immediate: true,
        onRegisteredSW(_swUrl, registration) {
          if (!registration) return;
          // Periodically check for an updated SW (every 60 minutes when online).
          setInterval(() => {
            if (navigator.onLine) registration.update().catch(() => {});
          }, 60 * 60 * 1000);
        },
      });
      void updateSW;
    </script>
  </body>
</html>
